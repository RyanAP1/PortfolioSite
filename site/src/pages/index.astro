---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Ryan Paredes — Technical Leader, Platform, Infrastructure, Security & DevOps">

  <!-- Hero / About -->
  <section id="about" class="mx-auto max-w-6xl px-6 py-20">
    <div class="flex flex-col items-center text-center">
      <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">
        Ryan <span class="text-primary-600 dark:text-primary-400">Paredes</span>
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-gray-600 dark:text-gray-300">
        Engineering and Product leader driving cloud platform strategy, security programs, developer experience,
        and delivery excellence across cross-functional teams.
      </p>
      <div class="mt-8 flex gap-4">
        <a
          href="https://www.linkedin.com/in/ryan-paredes/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-primary-700 transition-colors"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a
          href="https://github.com/RyanAP1/PortfolioSite"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-5 py-2.5 text-sm font-medium hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800 transition-colors"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          GitHub
        </a>
        <a
          href="/resumes/RyanPResumeEmail.pdf"
          target="_blank"
          class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-5 py-2.5 text-sm font-medium hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-800 transition-colors"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
          Resume PDF
        </a>
      </div>
    </div>
  </section>

  <!-- Skills & Tools -->
  <section id="skills" class="border-t border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="text-center text-2xl font-bold sm:text-3xl">Skills &amp; Tools</h2>
      <p class="mt-2 text-center text-gray-600 dark:text-gray-400">Technical expertise and leadership capabilities — hover for details</p>

      <!-- Technical Skills -->
      <h3 class="mt-10 text-center text-lg font-semibold text-gray-700 dark:text-gray-300">Technical</h3>
      <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
        {[
          { name: 'AWS', icon: '☁️', detail: 'GovCloud experience, multi-account architecture (20+), EKS, S3, CloudFront, Route 53, ACM, EC2, IAM' },
          { name: 'Kubernetes', icon: '⎈', detail: 'EKS cluster management, zero-downtime migrations, multi-environment deployments, containerized workloads' },
          { name: 'Terraform', icon: '🏗️', detail: 'Infrastructure as Code, modular architecture, multi-workspace management (dev/prod), state management' },
          { name: 'CI/CD', icon: '🔄', detail: 'GitHub Actions, GitLab CI, pipeline design, automated deployments, security scanning (Trivy, gitleaks)' },
          { name: 'Observability', icon: '📊', detail: 'Grafana, Datadog, SLA/SLO definition, reliability dashboards, platform adoption metrics' },
          { name: 'Python', icon: '🐍', detail: 'Automation scripting, data pipelines, API integrations' },
          { name: 'JavaScript', icon: '✨', detail: 'Web development, Astro, Node.js, blockchain/API integrations (DC3.Wiki)' },
          { name: 'DevSecOps', icon: '🔒', detail: 'Chainguard, Trivy scanning, supply-chain security, secret management, 200+ repo governance' },
        ].map((skill) => (
          <div class="skill-card group relative flex flex-col items-center rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm transition-all hover:shadow-md hover:border-primary-300 dark:border-gray-700 dark:bg-gray-800 dark:hover:border-primary-600 cursor-default">
            <span class="text-2xl">{skill.icon}</span>
            <span class="mt-2 text-sm font-medium">{skill.name}</span>
            <div class="skill-tooltip pointer-events-none absolute bottom-full left-1/2 z-20 mb-2 w-64 -translate-x-1/2 rounded-lg bg-gray-900 px-3 py-2 text-xs text-white opacity-0 shadow-lg transition-opacity group-hover:opacity-100 dark:bg-gray-700">
              {skill.detail}
              <div class="absolute left-1/2 top-full -translate-x-1/2 border-4 border-transparent border-t-gray-900 dark:border-t-gray-700"></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Process & Leadership Skills -->
      <h3 class="mt-10 text-center text-lg font-semibold text-gray-700 dark:text-gray-300">Process &amp; Leadership</h3>
      <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-3">
        {[
          { name: 'Product Management', icon: '📋', detail: 'Roadmap ownership, backlog prioritization, user feedback loops, adoption metrics, KPI definition' },
          { name: 'Program Management', icon: '🎯', detail: 'Cross-org coordination (100+ engineers), dependency tracking, quarterly planning cycles, executive reporting' },
          { name: 'Agile & Scrum', icon: '🔁', detail: 'Scrum Master, Agile coaching, Kanban, sprint planning, team velocity optimization, mentoring PMs' },
          { name: 'Stakeholder Alignment', icon: '🤝', detail: 'Executive presentations, investment tradeoff analysis, cross-functional partnership (Eng/Security/Product)' },
          { name: 'Change Management', icon: '📝', detail: 'CAB program creation, governance frameworks, approval workflows, ITIL/ITSM, regulatory compliance (healthcare)' },
          { name: 'Data-Driven Delivery', icon: '📈', detail: 'Velocity/cycle time tracking, delivery dashboards (Jira), release frequency metrics, program-level reporting' },
        ].map((skill) => (
          <div class="skill-card group relative flex flex-col items-center rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm transition-all hover:shadow-md hover:border-primary-300 dark:border-gray-700 dark:bg-gray-800 dark:hover:border-primary-600 cursor-default">
            <span class="text-2xl">{skill.icon}</span>
            <span class="mt-2 text-sm font-medium">{skill.name}</span>
            <div class="skill-tooltip pointer-events-none absolute bottom-full left-1/2 z-20 mb-2 w-64 -translate-x-1/2 rounded-lg bg-gray-900 px-3 py-2 text-xs text-white opacity-0 shadow-lg transition-opacity group-hover:opacity-100 dark:bg-gray-700">
              {skill.detail}
              <div class="absolute left-1/2 top-full -translate-x-1/2 border-4 border-transparent border-t-gray-900 dark:border-t-gray-700"></div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="border-t border-gray-200 dark:border-gray-800">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="text-center text-2xl font-bold sm:text-3xl">Projects</h2>
      <p class="mt-2 text-center text-gray-600 dark:text-gray-400">Infrastructure and automation work</p>
      <div class="mt-10 grid gap-6 md:grid-cols-2">

        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="flex items-start justify-between">
            <h3 class="text-lg font-semibold">PortfolioSite</h3>
            <span class="rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900 dark:text-green-300">Live</span>
          </div>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            This site — a fully automated portfolio deployed to AWS via GitHub Actions. Infrastructure managed with Terraform, 
            security scanning with Trivy, and built with Astro + Tailwind CSS.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {['AWS', 'Terraform', 'GitHub Actions', 'Astro', 'S3', 'CloudFront'].map((tag) => (
              <span class="rounded-md bg-primary-50 px-2 py-1 text-xs font-medium text-primary-700 dark:bg-primary-900/30 dark:text-primary-300">{tag}</span>
            ))}
          </div>
          <a
            href="https://github.com/RyanAP1/PortfolioSite"
            target="_blank"
            rel="noopener"
            class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400"
          >
            View on GitHub →
          </a>
        </div>

        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="flex items-start justify-between">
            <h3 class="text-lg font-semibold">DC3.Wiki</h3>
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 dark:bg-blue-900 dark:text-blue-300">Project</span>
          </div>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            A user-facing analytics platform for DC NFT collectors, providing real-time visibility into asset ownership,
            supply, and transaction activity through blockchain integrations. Built data pipelines to transform on-chain
            data into intuitive dashboards, iterating on features based on user behavior and feedback.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {['Blockchain', 'APIs', 'Data Pipelines', 'Analytics', 'JavaScript', 'Smart Contracts'].map((tag) => (
              <span class="rounded-md bg-primary-50 px-2 py-1 text-xs font-medium text-primary-700 dark:bg-primary-900/30 dark:text-primary-300">{tag}</span>
            ))}
          </div>
          <a
            href="https://dc3.wiki"
            target="_blank"
            rel="noopener"
            class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400"
          >
            Visit DC3.Wiki →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- CI/CD Pipeline Showcase -->
  <section id="pipeline" class="border-t border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="text-center text-2xl font-bold sm:text-3xl">CI/CD Pipeline</h2>
      <p class="mt-2 text-center text-gray-600 dark:text-gray-400">How this site gets built and deployed — fully automated with GitHub Actions</p>

      <div class="mt-10 flex flex-col items-center gap-4 md:flex-row md:justify-center">
        {[
          { stage: 'Lint', desc: 'Terraform fmt + Astro check', icon: '🔍' },
          { stage: 'Scan', desc: 'Trivy IaC & dependency scan', icon: '🛡️' },
          { stage: 'Build', desc: 'Astro static site build', icon: '🔨' },
          { stage: 'Deploy Dev', desc: 'S3 sync to dev bucket', icon: '🚀' },
          { stage: 'Deploy Prod', desc: 'Approval gate + S3 sync', icon: '✅' },
        ].map((step, i) => (
          <div class="flex items-center gap-4">
            <div class="flex w-40 flex-col items-center rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm dark:border-gray-700 dark:bg-gray-800">
              <span class="text-2xl">{step.icon}</span>
              <span class="mt-1 text-sm font-semibold">{step.stage}</span>
              <span class="mt-1 text-xs text-gray-500 dark:text-gray-400">{step.desc}</span>
            </div>
            {i < 4 && (
              <span class="hidden text-gray-400 md:block">→</span>
            )}
          </div>
        ))}
      </div>

      <div class="mt-8 rounded-xl border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-800">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Pipeline Details</h3>
        <ul class="mt-3 space-y-2 text-sm text-gray-600 dark:text-gray-300">
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-green-500">✓</span>
            <span><strong>Lint:</strong> Terraform files validated with <code class="rounded bg-gray-100 px-1 dark:bg-gray-700">terraform fmt -check</code> and site checked with <code class="rounded bg-gray-100 px-1 dark:bg-gray-700">astro check</code></span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-green-500">✓</span>
            <span><strong>Security Scan:</strong> Trivy scans IaC for misconfigurations and dependencies for known CVEs (pinned version to avoid supply-chain risk)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-green-500">✓</span>
            <span><strong>Build:</strong> Astro generates optimized static HTML/CSS/JS with zero JavaScript shipped to the client by default</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-green-500">✓</span>
            <span><strong>Deploy Dev:</strong> Built artifacts synced to S3 dev bucket automatically on push to <code class="rounded bg-gray-100 px-1 dark:bg-gray-700">main</code></span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-green-500">✓</span>
            <span><strong>Deploy Prod:</strong> GitHub Environment protection rules require manual approval before syncing to the production S3 bucket behind CloudFront</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 text-green-500">✓</span>
            <span><strong>Secrets:</strong> gitleaks pre-commit hooks + CI scanning prevent accidental credential leaks</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section id="architecture" class="border-t border-gray-200 dark:border-gray-800">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="text-center text-2xl font-bold sm:text-3xl">Architecture</h2>
      <p class="mt-2 text-center text-gray-600 dark:text-gray-400">AWS infrastructure powering this site</p>
      <div class="mt-10 flex justify-center">
        <div class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <pre class="text-xs leading-relaxed text-gray-700 dark:text-gray-300 sm:text-sm"><code>┌────────────┐     ┌──────────────┐     ┌────────────┐
│            │     │              │     │            │
│  Route 53  │────▶│  CloudFront  │────▶│  S3 Bucket │
│  (DNS)     │     │  (CDN+TLS)   │     │  (Static)  │
│            │     │              │     │            │
└────────────┘     └──────────────┘     └────────────┘
       │                  │
       │           ┌──────────────┐
       │           │     ACM      │
       └──────────▶│ (TLS Cert)   │
                   └──────────────┘</code></pre>
        </div>
      </div>
      <p class="mt-6 text-center text-sm text-gray-500 dark:text-gray-400">
        All infrastructure defined as Terraform modules — see the
        <a href="https://github.com/RyanAP1/PortfolioSite" target="_blank" rel="noopener" class="text-primary-600 hover:text-primary-700 dark:text-primary-400">repo</a>
        for full source.
      </p>

      <!-- CI/CD Technical Diagram -->
      <h3 class="mt-14 text-center text-xl font-bold sm:text-2xl">CI/CD Pipeline Detail</h3>
      <p class="mt-2 text-center text-gray-600 dark:text-gray-400">End-to-end automation across three GitHub Actions workflows</p>
      <div class="mt-8 flex justify-center overflow-x-auto">
        <div class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <pre class="text-xs leading-relaxed text-gray-700 dark:text-gray-300 sm:text-sm"><code>                         ┌──────────────────────────────────────┐
                         │          GitHub Repository           │
                         │            (main branch)             │
                         └──────────┬───────────┬───────────────┘
                                    │           │
                    push/PR (site/) │           │ push/PR (infra/)
                                    ▼           ▼
              ┌─────────────────────────┐  ┌─────────────────────────┐
              │   CI Workflow (ci.yml)  │  │  IaC Workflow (iac.yml) │
              │                         │  │                         │
              │  ┌───────┐ ┌─────────┐  │  │  ┌──────────────────┐   │
              │  │ Lint  │ │ Secrets │  │  │  │ Terraform Cloud  │   │
              │  │ Astro │ │gitleaks │  │  │  │  Init / Validate │   │
              │  │ check │ │  scan   │  │  │  │    Plan / Apply  │   │
              │  └───┬───┘ └────┬────┘  │  │  └────────┬─────────┘   │
              │      │          │       │  │           │             │
              │  ┌───┴──────────┴────┐  │  │  ┌────────▼─────────┐   │
              │  │   Trivy Scanner   │  │  │  │ PR Plan Comment  │   │
              │  │ IaC misconfig +   │  │  │  │ (auto-posted)    │   │
              │  │ dependency CVEs   │  │  │  └──────────────────┘   │
              │  └────────┬──────────┘  │  └─────────────────────────┘
              │           │             │
              │  ┌────────▼──────────┐  │
              │  │   Astro Build     │  │
              │  │  (Node 22 + npm)  │  │
              │  └────────┬──────────┘  │
              └───────────┼─────────────┘
                          │
              ┌───────────▼─────────────────────────────────────┐
              │        Deploy Workflow (deploy.yml)              │
              │                                                  │
              │  ┌──────────────┐        ┌───────────────────┐   │
              │  │  Build       │        │  Manual Dispatch   │   │
              │  │  Artifact    │        │  (workflow_dispatch)│  │
              │  └──────┬───────┘        └─────────┬─────────┘   │
              │         │ auto on push             │ manual      │
              │         ▼                          ▼             │
              │  ┌──────────────┐        ┌───────────────────┐   │
              │  │  Deploy Dev  │        │  Deploy Prod      │   │
              │  │              │        │                   │   │
              │  │  AWS Creds   │        │  ┌─────────────┐  │   │
              │  │  (OIDC)      │        │  │  Approval   │  │   │
              │  │      │       │        │  │  Gate       │  │   │
              │  │      ▼       │        │  └──────┬──────┘  │   │
              │  │  S3 Sync     │        │         ▼         │   │
              │  │  (Dev Bucket)│        │  AWS Creds (OIDC) │   │
              │  └──────────────┘        │         │         │   │
              │                          │         ▼         │   │
              │                          │  S3 Sync (Prod)   │   │
              │                          │         │         │   │
              │                          │         ▼         │   │
              │                          │  CloudFront       │   │
              │                          │  Cache Invalidate │   │
              │                          └───────────────────┘   │
              └──────────────────────────────────────────────────┘</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Integration -->
  <section id="ai" class="border-t border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="text-center text-2xl font-bold sm:text-3xl">AI-Integrated Workflow</h2>
      <p class="mt-2 max-w-2xl mx-auto text-center text-gray-600 dark:text-gray-400">
        AI isn't a novelty in my workflow — it's embedded across engineering, planning, and delivery. Here's how I integrate AI tools daily.
      </p>
      <div class="mt-10 grid gap-6 md:grid-cols-3">

        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="flex items-center gap-3">
            <span class="text-2xl">💻</span>
            <h3 class="text-lg font-semibold">GitHub Copilot</h3>
          </div>
          <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
            Inline code generation, Terraform module scaffolding, CI/CD workflow authoring, and real-time code review.
            Used across infrastructure, automation scripts, and frontend development as a daily pair programmer.
          </p>
        </div>

        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="flex items-center gap-3">
            <span class="text-2xl">🧠</span>
            <h3 class="text-lg font-semibold">Claude Code</h3>
          </div>
          <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
            Deep architecture reasoning, security auditing, and complex multi-file refactoring.
            Used for evaluating design tradeoffs, identifying vulnerabilities, and building out end-to-end features
            with full codebase context.
          </p>
        </div>

        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
          <div class="flex items-center gap-3">
            <span class="text-2xl">✨</span>
            <h3 class="text-lg font-semibold">Google Gemini</h3>
          </div>
          <p class="mt-3 text-sm text-gray-600 dark:text-gray-400">
            Program and product management workflows — drafting roadmap narratives, synthesizing stakeholder feedback,
            building executive summaries, and structuring quarterly planning documents.
            Integrated into everyday process work, not just engineering.
          </p>
        </div>

      </div>

      <div class="mt-8 rounded-xl border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-800">
